# ─── SUPABASE (base de datos) ─────────────────────────────────────────────
# Ve a supabase.com → New project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── ANTHROPIC (agente IA + agente de contenido) ─────────────────────────
# Ve a console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Modelo del agente de WhatsApp (opcional, por defecto claude-opus-4-8):
ANTHROPIC_MODEL=claude-opus-4-8

# ─── WHATSAPP CLOUD API (captación de proveedores por WhatsApp) ───────────
# Meta → developers.facebook.com → tu app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=1234567890         # ID del número emisor
WHATSAPP_TOKEN=EAAG...                       # token permanente del System User
WHATSAPP_APP_SECRET=...                       # App Secret (verifica la firma del webhook)
WHATSAPP_VERIFY_TOKEN=un_texto_secreto_que_tu_eliges
# Nombre de la plantilla de captación APROBADA en Meta ({{1}} = nombre del proveedor).
# Requerido para el botón "Enviar plantilla de captación".
WHATSAPP_OUTREACH_TEMPLATE=fiestago_outreach
# Opcionales:
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_TEMPLATE_LANG=es

# ─── FAL.AI (generación de imágenes y vídeo del agente de contenido) ─────
# Ve a fal.ai → Dashboard → API Keys
FAL_API_KEY=...

# ─── STRIPE (pagos) ───────────────────────────────────────────────────────
# Ve a dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── EMAILJS (emails de outreach) ─────────────────────────────────────────
# Ve a emailjs.com → Account → API Keys
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_...
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_...
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=...

# ─── APIFY (scraping Instagram/TikTok) ────────────────────────────────────
# Ve a apify.com → Settings → Integrations
APIFY_API_KEY=apify_api_...

# ─── ADMIN ────────────────────────────────────────────────────────────────
# Contraseña de acceso al panel de administración
ADMIN_PASSWORD=fiegago_admin_2024
ADMIN_EMAIL=admin@fiegago.es

# ─── APP ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://fiegago.vercel.app
NEXT_PUBLIC_APP_NAME=FiestaGo
