# ─── FAL.AI (generación de imágenes y vídeo del agente de contenido) ─────
# Ve a fal.ai → Dashboard → API Keys
FAL_API_KEY=...

# ─── STRIPE (pagos) ───────────────────────────────────────────────────────
# Ve a dashboard.stripe.com → Developers → API Keys
