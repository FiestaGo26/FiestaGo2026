STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── EMAILJS (emails de outreach) ─────────────────────────────────────────
# Ve a emailjs.com → Account → API Keys
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_...
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_...
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=...

# ─── APIFY (scraping Instagram/TikTok) ────────────────────────────────────
# Ve a apify.com → Settings → Integrations
APIFY_API_KEY=apify_api_...

# ─── ADMIN ────────────────────────────────────────────────────────────────
# Contraseña de acceso al panel de administración
ADMIN_PASSWORD=fiegago_admin_2024
ADMIN_EMAIL=admin@fiegago.es

# ─── WHATSAPP (agente conversacional de captación) ────────────────────────
# Meta WhatsApp Cloud API — developers.facebook.com → tu App → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAG...                 # token permanente de la app de Meta
WHATSAPP_PHONE_ID=1234567890           # Phone Number ID del número de WhatsApp Business
WHATSAPP_VERIFY_TOKEN=un_secreto_largo # cadena que tú inventas; se pega también en el webhook de Meta
WHATSAPP_GRAPH_VERSION=v21.0           # opcional
# Modelo de Claude para las respuestas conversacionales (opcional)
CONVERSATION_MODEL=claude-sonnet-4-6

# ─── APP ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://fiegago.vercel.app
NEXT_PUBLIC_APP_NAME=FiestaGo
